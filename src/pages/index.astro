---
import "../styles/global.css";
import Header from "../components/header";
import HeroSection from "../components/hero-section";
import GuidesSection from "../components/guides-section";
import CtaSection from "../components/cta-section";
import Footer from "../components/footer";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>OKX Trade Skills — Onchain Trading with AI Agents</title>
		<meta
			name="description"
			content="A skill library for autonomous onchain trading. Research tokens, scan for honeypots, execute swaps, track smart money, and run DeFi strategies across EVM chains and Solana."
		/>
		<meta
			name="keywords"
			content="OKX, onchain trading, AI agents, DeFi, DEX, swap, crypto trading, autonomous trading, skill library"
		/>
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href="https://okxskills.netlify.app/" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta
			property="og:title"
			content="OKX Trade Skills — Onchain Trading with AI Agents"
		/>
		<meta
			property="og:description"
			content="A skill library for autonomous onchain trading. Research tokens, execute swaps, track smart money, and run DeFi strategies across chains."
		/>
		<meta property="og:url" content="https://okxskills.netlify.app/" />
		<meta property="og:site_name" content="OKX Trade Skills" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta
			name="twitter:title"
			content="OKX Trade Skills — Onchain Trading with AI Agents"
		/>
		<meta
			name="twitter:description"
			content="A skill library for autonomous onchain trading. Research tokens, execute swaps, track smart money, and run DeFi strategies across chains."
		/>
	</head>
	<body>
		<Header />
		<HeroSection />
		<GuidesSection />
		<CtaSection />
		<Footer />
	</body>
</html>
