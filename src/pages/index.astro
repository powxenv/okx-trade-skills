---
import "../styles/global.css";
import Header from "../components/header";
import HeroSection from "../components/hero-section";
import OkxTrading from "../components/okx-trading";
import Uniswap from "../components/uniswap";
import UniswapDev from "../components/uniswap-dev";
import XlayerAgent from "../components/xlayer-agent";
import PortfolioGuardian from "../components/portfolio-guardian";
import MemeIntelligence from "../components/meme-intelligence";
import EcosystemSection from "../components/ecosystem-section";
import CtaSection from "../components/cta-section";
import Footer from "../components/footer";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>OKX Trade Skills — An Onchain Skill Suite for AI Agents</title>
		<meta
			name="description"
			content="Give your AI agent the skills to trade, protect, and analyze onchain. Execute swaps, manage portfolios, catch meme gems, deploy Uniswap strategies, and monitor risk—all with built-in security."
		/>
		<meta
			name="keywords"
			content="AI agent skills, onchain trading, crypto agents, DeFi automation, portfolio monitoring, meme trading, Uniswap V4, X Layer, autonomous trading, smart money tracking, stop-loss automation"
		/>
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href="https://okxskills.noval.me/" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta
			property="og:title"
			content="OKX Trade Skills — An Onchain Skill Suite for AI Agents"
		/>
		<meta
			property="og:description"
			content="Give your AI agent the skills to trade, protect, and analyze onchain. Execute swaps, manage portfolios, catch meme gems, deploy Uniswap strategies, and monitor risk—all with built-in security."
		/>
		<meta property="og:url" content="https://okxskills.noval.me/" />
		<meta property="og:site_name" content="OKX Trade Skills" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta
			name="twitter:title"
			content="OKX Trade Skills — An Onchain Skill Suite for AI Agents"
		/>
		<meta
			name="twitter:description"
			content="Give your AI agent the skills to trade, protect, and analyze onchain. Execute swaps, manage portfolios, catch meme gems, deploy Uniswap strategies, and monitor risk—all with built-in security."
		/>
	</head>
	<body>
		<Header client:load />
		<HeroSection client:load />
		<OkxTrading client:load />
		<Uniswap client:load />
		<UniswapDev client:load />
		<XlayerAgent client:load />
		<PortfolioGuardian client:load />
		<MemeIntelligence client:load />
		<EcosystemSection client:load />
		<CtaSection client:load />
		<Footer client:load />
	</body>
</html>
